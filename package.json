{
  "name": "wali-s-workout",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "verify": "npm run verify:adherence && npm run verify:alternatives && npm run verify:consistency && npm run verify:load && npm run verify:missed-workout && npm run verify:muscle-exposure && npm run verify:modifications && npm run verify:notifications && npm run verify:one-rm && npm run verify:personal-records && npm run verify:progression && npm run verify:program-seed && npm run verify:rest-timer && npm run verify:schema && npm run verify:seed-resolver && npm run verify:seed-alternatives && npm run verify:session-planner && npm run verify:settings && npm run verify:weekly-volume && npm run verify:workout-log && npm run verify:year && npm run typecheck",
    "verify:adherence": "node --experimental-strip-types scripts/verify-adherence.mjs",
    "verify:alternatives": "node --experimental-strip-types scripts/verify-alternatives.mjs",
    "verify:consistency": "node --experimental-strip-types scripts/verify-consistency-calendar.mjs",
    "verify:load": "node --experimental-strip-types scripts/verify-load-calculator.mjs",
    "verify:missed-workout": "node --experimental-strip-types scripts/verify-missed-workout.mjs",
    "verify:muscle-exposure": "node --experimental-strip-types scripts/verify-muscle-exposure.mjs",
    "verify:modifications": "node --experimental-strip-types scripts/verify-modification-resolver.mjs",
    "verify:notifications": "node --experimental-strip-types scripts/verify-notifications.mjs",
    "verify:one-rm": "node --experimental-strip-types scripts/verify-one-rm-vault.mjs",
    "verify:personal-records": "node --experimental-strip-types scripts/verify-personal-records.mjs",
    "verify:progression": "node --experimental-strip-types scripts/verify-progression.mjs",
    "verify:program-seed": "node --experimental-strip-types scripts/verify-program-seed.mjs",
    "verify:rest-timer": "node --experimental-strip-types scripts/verify-rest-timer.mjs",
    "verify:schema": "node scripts/verify-schema.mjs",
    "verify:seed-resolver": "node --experimental-strip-types scripts/verify-seed-resolver.mjs",
    "verify:seed-alternatives": "node --experimental-strip-types scripts/verify-seed-alternatives.mjs",
    "verify:session-planner": "node --experimental-strip-types scripts/verify-session-planner.mjs",
    "verify:settings": "node --experimental-strip-types scripts/verify-settings.mjs",
    "verify:weekly-volume": "node --experimental-strip-types scripts/verify-weekly-volume.mjs",
    "verify:workout-log": "node --experimental-strip-types scripts/verify-workout-log.mjs",
    "verify:year": "node --experimental-strip-types scripts/verify-year-engine.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~57.0.4",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  }
}

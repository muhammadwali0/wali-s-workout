    "verify:muscle-exposure": "node --experimental-strip-types scripts/verify-muscle-exposure.mjs",
    "verify:modifications": "node --experimental-strip-types scripts/verify-modification-resolver.mjs",
    "verify:notifications": "node --experimental-strip-types scripts/verify-notifications.mjs",
    "verify:personal-records": "node --experimental-strip-types scripts/verify-personal-records.mjs",
    "verify:program-seed": "node --experimental-strip-types scripts/verify-program-seed.mjs",
    "verify:rest-timer": "node --experimental-strip-types scripts/verify-rest-timer.mjs",
